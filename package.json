{
  "name": "movilex",
  "version": "1.0.0",
  "description": "File manager for prof",
  "main": "app/main/main.js",
  "author": {
    "name": "Abhishekh",
    "email": "abhishekhinbox@gmail.com"
  },
  "license": "ISC",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron --no-sandbox .\"",
    "build:renderer": "vite build",
    "build": "npm run build:renderer",
    "dist": "npm run build && electron-builder",
    "linux": "npm run build && electron-builder --linux",
    "mac": "npm run build && electron-builder --mac",
    "win": "npm run build && electron-builder --win",
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "lucide-react": "^1.14.0",
    "pdfjs-dist": "^3.11.174",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.8",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.movilex.app",
    "productName": "Movilex",
    "icon": "build/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "app/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
